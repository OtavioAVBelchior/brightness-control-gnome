{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "noImplicitAny": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "skipLibCheck": true,
    "paths": {
      "gi://Gio": ["./node_modules/@girs/gio-2.0"],
      "gi://Gio?version=2.0": ["./node_modules/@girs/gio-2.0"],
      "gi://GLib": ["./node_modules/@girs/glib-2.0"],
      "gi://GLib?version=2.0": ["./node_modules/@girs/glib-2.0"],
      "gi://GObject": ["./node_modules/@girs/gobject-2.0"],
      "gi://GObject?version=2.0": ["./node_modules/@girs/gobject-2.0"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
